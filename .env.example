# =====================================================
# PORTALIA REVENUE OS — Variables de Entorno
# =====================================================
# Copia este archivo como .env.local para desarrollo
# NUNCA subas .env.local ni .env.production al repositorio
# NUNCA ingreses valores reales en este archivo

# ---- MODO DE OPERACIÓN ----
# true = usa datos mock (maqueta)
# false = usa servicios reales (requiere todas las variables abajo)
VITE_USE_MOCK=true

# ---- FEATURE FLAGS (desactivados hasta Entrega 3) ----
VITE_SUPABASE_ENABLED=false
VITE_TWILIO_ENABLED=false
VITE_OPENAI_ENABLED=false
VITE_WHATSAPP_ENABLED=false
VITE_EMAIL_ENABLED=false

# ---- SUPABASE (no conectar hasta Entrega 3) ----
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- OPENAI (no conectar hasta Entrega 3) ----
# VITE_OPENAI_API_KEY=sk-...
# NOTA: En producción, las llamadas a OpenAI deben hacerse
#       desde Edge Functions, NUNCA desde el cliente

# ---- TWILIO (no conectar hasta Entrega 3) ----
# VITE_TWILIO_ACCOUNT_SID=AC...
# VITE_TWILIO_AUTH_TOKEN=...
# NOTA: Las credenciales Twilio NUNCA deben estar en el frontend
#       Usar Edge Functions de Supabase como proxy

# ---- WHATSAPP (no conectar hasta Entrega 3) ----
# VITE_WHATSAPP_PHONE_NUMBER_ID=...
# VITE_WHATSAPP_ACCESS_TOKEN=...
# NOTA: Igual que Twilio — solo via Edge Functions

# ---- EMAIL (no conectar hasta Entrega 3) ----
# VITE_RESEND_API_KEY=re_...

# ---- CONFIGURACIÓN DE APP ----
VITE_APP_NAME=Portalia Revenue OS
VITE_APP_VERSION=0.1.0
