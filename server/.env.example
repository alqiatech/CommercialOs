# Variables de entorno para el servidor IA de Portalia
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Estas variables NUNCA deben estar en el frontend ni usar el
# prefijo VITE_. Las variables con VITE_ quedan expuestas en el bundle público.
# ─────────────────────────────────────────────────────────────────────────────

# Puerto del servidor Express (default: 3001)
PORT=3001

# Origen permitido para CORS (el frontend de Vite)
CORS_ORIGIN=http://localhost:5173

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Clave de API de OpenAI — solo vive en el servidor, jamás en el cliente
OPENAI_API_KEY=sk-...tuClaveAqui...

# Modelo a usar (gpt-4o-mini es el más barato para demos)
OPENAI_MODEL=gpt-4o-mini

# ─── Modo de operación ───────────────────────────────────────────────────────
# 'mock'  → respuestas simuladas (para demos sin gastar tokens)
# 'real'  → llama a OpenAI con tu clave real
AI_MODE=mock

# ─── Twilio (se configura en producción) ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_FROM=+1...

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# WA_PHONE_NUMBER_ID=...
# WA_ACCESS_TOKEN=...

# ─── Resend ───────────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...

# ─── Supabase (backend — nunca en frontend) ───────────────────────────────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
